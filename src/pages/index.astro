---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import PostCard from '../components/PostCard.astro';

const allPosts = await getCollection('posts');
const sorted = allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const recent = sorted.slice(0, 6);
---

<Base title="Home" description="Ambient Fam — an ambient music community on Twitch and beyond.">
  <div class="home-hero">
    <h1>Ambient Fam</h1>
    <p>A community of ambient musicians streaming on Twitch and releasing music into the world.</p>
  </div>

  <section>
    <div class="section-header">
      <h2>Latest</h2>
      <a href="/music">See all music →</a>
    </div>
    <div class="post-grid">
      {recent.map(post => (
        <PostCard
          title={post.data.title}
          slug={post.slug}
          pubDate={post.data.pubDate}
          category={post.data.category}
          excerpt={post.data.excerpt}
          artist={post.data.artist}
          bandcampLink={post.data.bandcampLink}
        />
      ))}
    </div>
  </section>
</Base>
