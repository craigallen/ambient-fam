---
interface Props {
  title: string;
  slug: string;
  pubDate: Date;
  category: string;
  excerpt?: string;
  artist?: string;
  image?: string;
  bandcampLink?: string;
}

const { title, slug, pubDate, category, excerpt, artist, image, bandcampLink } = Astro.props;

const href = bandcampLink ?? `/posts/${slug}`;
const external = !!bandcampLink;
---

<a href={href} class="post-card" target={external ? '_blank' : undefined} rel={external ? 'noopener noreferrer' : undefined}>
  <div class="card-img-wrap">
    {image
      ? <img src={image} alt={title} loading="lazy" />
      : <div class="card-img-placeholder">{title[0]}</div>
    }
  </div>
  <h2>{title}</h2>
  {artist && <p class="card-sub">{artist}</p>}
  {!artist && excerpt && <p class="card-sub">{excerpt}</p>}
</a>
