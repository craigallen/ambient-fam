---
interface Props {
  title: string;
  slug: string;
  pubDate: Date;
  category: string;
  excerpt?: string;
  artist?: string;
  bandcampLink?: string;
}

const { title, slug, pubDate, category, excerpt, artist, bandcampLink } = Astro.props;

const dateStr = pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
---

<a href={`/posts/${slug}`} class="post-card">
  <div class="post-card-meta">
    <span class="category-badge">{category}</span>
    <time datetime={pubDate.toISOString()}>{dateStr}</time>
  </div>
  <h2>{title}</h2>
  {artist && <p class="artist">{artist}</p>}
  {excerpt && <p class="excerpt">{excerpt}</p>}
  {bandcampLink && <span class="bandcamp-link">Listen on Bandcamp →</span>}
</a>
