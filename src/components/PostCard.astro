---
interface Props {
  title: string;
  slug: string;
  pubDate: Date;
  category: string;
  excerpt?: string;
  artist?: string;
  image?: string;
  bandcampLink?: string;
}

const { title, slug, pubDate, category, excerpt, artist, image } = Astro.props;
---

<a href={`/posts/${slug}`} class="post-card">
  <div class="card-img-wrap">
    {image
      ? <img src={image} alt={title} loading="lazy" />
      : <div class="card-img-placeholder">{title[0]}</div>
    }
  </div>
  <h2>{title}</h2>
  {artist && <p class="card-sub">{artist}</p>}
  {!artist && excerpt && <p class="card-sub">{excerpt}</p>}
</a>
